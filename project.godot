[application]

config/name="Grave Danger"
run/main_scene="res://ui/screens/title_screen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Assets/frontend/icon.svg"

[autoload]

quick_exit="*res://autoload/quick_exit.gd"
ResultStats="*res://autoload/result_stats.gd"
LevelSelection="*res://autoload/level_selection.gd"
SimpleGrass="*uid://bfq0snth8sj3h"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3

[editor_plugins]

enabled=PackedStringArray("res://addons/png_to_gridmap/plugin.cfg", "res://addons/simplegrasstextured/plugin.cfg")

[gameplay]

